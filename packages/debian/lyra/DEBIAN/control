Package: lyra
Version: 1.1.0-1
Section: utils
Priority: optional
Architecture: amd64
Depends: python3 (>= 3.13),
         python3-fastapi,
         python3-uvicorn,
         python3-pydantic,
         python3-markdown,
         python3-huggingface-hub,
         python3-numpy,
         python3-regex,
         python3-tqdm,
         python3-requests,
         libgtk-3-0,
         libnss3,
